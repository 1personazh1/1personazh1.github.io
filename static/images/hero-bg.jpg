<?xml version="1.0" encoding="UTF-8"?>
<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="600" viewBox="0 0 1200 600">
  <defs>
    <linearGradient id="bgGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#1a1a1a" />
      <stop offset="100%" stop-color="#0d0d0d" />
    </linearGradient>
    <pattern id="racingStripes" patternUnits="userSpaceOnUse" width="40" height="40" patternTransform="rotate(45)">
      <rect width="20" height="40" fill="#ff3333" />
      <rect x="20" width="20" height="40" fill="#1a1a1a" />
    </pattern>
  </defs>
  <rect width="1200" height="600" fill="url(#bgGradient)" />
  <rect width="1200" height="600" fill="url(#racingStripes)" opacity="0.1" />
  <text x="600" y="300" font-family="Arial, sans-serif" font-size="48" fill="#ff3333" text-anchor="middle">JDM HERO BACKGROUND</text>
  <g stroke="#ff3333" stroke-width="2" fill="none">
    <circle cx="600" cy="300" r="100" stroke-dasharray="10,5" />
    <circle cx="600" cy="300" r="150" stroke-dasharray="10,5" />
    <circle cx="600" cy="300" r="200" stroke-dasharray="10,5" />
  </g>
</svg>